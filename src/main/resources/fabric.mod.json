{
  "schemaVersion": 1,
  "id": "discify",
  "version": "${version}",
  "name": "Discify",
  "description": "Spotify controls and now-playing HUD in Minecraft — no Premium required for playback controls",
  "authors": [
    "SUHL2"
  ],
  "contact": {
    "sources": "https://github.com/erruqie/Discify"
  },
  "license": "CC0-1.0",
  "icon": "assets/discify/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "one.clownless.discify.DiscifyClient"
    ]
  },
  "mixins": [
    "discify.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "fabric-api": "*",
    "minecraft": "~26.1.2",
    "java": ">=25",
    "midnightlib": ">=1.9.3"
  },
  "custom": {
    "modmenu": {
      "links": {}
    }
  }
